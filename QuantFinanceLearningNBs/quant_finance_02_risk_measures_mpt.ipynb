    "print(f'  VaR(A)+VaR(B)={var_A+var_B:,.0f}€  vs.  VaR(A+B)={var_AB:,.0f}€')\n",
    "if var_AB <= var_A + var_B:\n",
    "    print('  → Subadditivität ERFÜLLT in diesem Fall (durch Diversifikation)')\n",
    "else:\n",
