    "# ── VaR Vergleich: Drei Methoden ──────────────────────────────────────────────\n",
    "port_vol = 0.18\n",
    "port_ret = 0.08\n",
    "pf_val   = 1_000_000\n",
    "\n",
    "daily_r = np.random.normal(port_ret/TRADING_DAYS, port_vol/np.sqrt(TRADING_DAYS), 10000)\n",
    "pnl     = daily_r * pf_val\n",
    "\n",
    "# ── Methode 1: Historische Simulation ────────────────────────────────────────\n",
    "var_hist_99 = -np.percentile(pnl, 1.0)\n",
    "es_hist_975 = -pnl[pnl <= np.percentile(pnl, 2.5)].mean()\n",
    "\n",
    "# ── Methode 2: Parametrisch (Normal) ─────────────────────────────────────────\n",
    "mu_pnl    = pnl.mean()\n",
    "sig_pnl   = pnl.std()\n",
    "z_99      = stats.norm.ppf(0.01)\n",
    "var_param = -(mu_pnl + z_99 * sig_pnl)\n",
    "# ES parametrisch: E[X | X < q_alpha] = mu - sig * phi(z_alpha)/alpha\n",
    "es_param  = -(mu_pnl - sig_pnl * stats.norm.pdf(z_99) / 0.025)\n",
    "\n",
    "# ── Methode 3: Monte Carlo (bereits in Projekt 1) ─────────────────────────────\n",
    "var_mc = var_hist_99  # gleich bei genug Simulationen\n",
    "\n",
    "print('VaR und CVaR Methodenvergleich (99% VaR / 97.5% ES):')\n",
    "print(f'  Historische Simulation : VaR={var_hist_99:,.0f}€, ES={es_hist_975:,.0f}€')\n",
    "print(f'  Parametrisch (Normal)  : VaR={var_param:,.0f}€, ES={es_param:,.0f}€')\n",
    "print(f'  Hinweis: Bei Normalverteilung sollten die Methoden übereinstimmen.')\n",
    "\n",
    "# ── Subadditivitäts-Verletzung von VaR ───────────────────────────────────────\n",
    "print('\\nDemonstration: VaR ist NICHT subadditiv (kann Diversifikation bestrafen)')\n",
    "# Zwei konzentrierte Positionen – jede für sich betrachtet vs. zusammen\n",
