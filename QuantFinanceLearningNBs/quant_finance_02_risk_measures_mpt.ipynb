    "# ── Estimation Error Demonstration ───────────────────────────────────────────\n",
    "# Zeige wie kleine Änderungen in mu zu sehr verschiedenen optimalen Portfolios führen\n",
    "np.random.seed(0)\n",
    "n_assets = 5\n",
    "names5   = ['SAP', 'Allianz', 'Siemens', 'BASF', 'RWE']\n",
    "true_mu  = np.array([0.10, 0.08, 0.09, 0.07, 0.06])\n",
    "vols5    = np.array([0.22, 0.18, 0.20, 0.24, 0.16])\n",
    "corr5    = np.array([[1,.4,.5,.4,.2],[.4,1,.5,.4,.3],[.5,.5,1,.5,.3],\n",
    "                     [.4,.4,.5,1,.3],[.2,.3,.3,.3,1]])\n",
    "cov5     = np.outer(vols5, vols5) * corr5\n",
    "\n",
    "def max_sharpe_weights(mu, cov, rf=RISK_FREE):\n",
    "    n = len(mu); w0 = np.ones(n)/n\n",
    "    res = minimize(lambda w: -(w@mu - rf)/np.sqrt(w@cov@w),\n",
    "                   w0, method='SLSQP',\n",
    "                   bounds=[(0,1)]*n,\n",
    "                   constraints=[{'type':'eq','fun':lambda w: w.sum()-1}],\n",
    "                   options={'ftol':1e-12,'maxiter':1000})\n",
    "    return res.x\n",
    "\n",
    "# Originale optimale Gewichte\n",
    "w_orig = max_sharpe_weights(true_mu, cov5)\n",
    "\n",
    "# Viele leicht gestörte mu-Schätzungen\n",
    "n_boot   = 50\n",
    "w_boots  = []\n",
    "for _ in range(n_boot):\n",
    "    mu_noisy = true_mu + np.random.normal(0, 0.005, n_assets)  # ±0.5% Schätzfehler\n",
    "    try:\n",
    "        w_b = max_sharpe_weights(mu_noisy, cov5)\n",
    "        w_boots.append(w_b)\n",
    "    except:\n",
    "        pass\n",
    "w_boots = np.array(w_boots)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Gewichtsstreuung\n",
    "bp = axes[0].boxplot(w_boots * 100, labels=names5, patch_artist=True)\n",
    "for patch in bp['boxes']:\n",
    "    patch.set_facecolor('#4a90d9'); patch.set_alpha(0.6)\n",
    "axes[0].plot(range(1, n_assets+1), w_orig * 100, 'r*', ms=12, zorder=5, label='Wahre Lösung')\n",
    "axes[0].set_ylabel('Portfolio-Gewicht (%)')\n",
    "axes[0].set_title('Estimation Error Problem:\\nGewichtsstreuung bei ±0.5% Rendite-Schätzfehler',\n",
    "                  fontweight='bold')\n",
    "axes[0].legend()\n",
    "\n",
    "# Standardabweichung der Gewichte\n",
    "weight_stds = w_boots.std(axis=0) * 100\n",
    "axes[1].bar(names5, weight_stds, color='#e74c3c', edgecolor='white')\n",
    "axes[1].set_ylabel('Std. Abweichung der Gewichte (%)')\n",
    "axes[1].set_title('Instabilität der Optimierung\\n(hoher Wert = unstabiles Gewicht)', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('estimation_error.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('Fazit: Kleine Schätzfehler führen zu stark variierenden optimalen Portfolios!')\n",
    "print('→ Das ist der Hauptgrund warum Minimum Variance und Risk Parity oft bevorzugt werden.')"
   ]
